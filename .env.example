# YouTube Transcript Exporter Environment Variables
# Copy this file to .env and fill in your actual values

# YouTube Data API Key (get from https://console.cloud.google.com)
YOUTUBE_API_KEY=your_key_here

# Notion Integration Token (optional, for Notion export)
NOTION_TOKEN=your_token_here

# Notion Database ID (optional, for Notion export)
NOTION_DATABASE_ID=your_database_id_here

# Advanced Configuration (optional, overrides config.json)
# MAX_WORKERS=4
# DOWNLOAD_TIMEOUT=300
# RETRY_ATTEMPTS=3
# OUTPUT_DIR=out
# MARKDOWN_DIR=markdown
# DB_PATH=db/canonical.json
# LOG_LEVEL=INFO
