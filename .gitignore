# ============================================================
# DATA -- Never commit. Users generate their own.
# ============================================================
# Raw yt-dlp downloads (channels' transcripts).
out/
# Generated Obsidian vault.
markdown/
# User-specific metadata DB and runtime state.
db/canonical.json
db/downloaded.txt
db/*.bak*
# Personal logs/old reports.
logs/
archive/
backups/
# User-specific channel list (use channels.txt.example as template).
channels.txt

# Allow the db/ folder to exist via a placeholder.
!db/.gitkeep

# ============================================================
# Logs
# ============================================================
*.log

